# Arquivo de exemplo com variáveis necessárias para executar os testes
# Copie para `.env` e ajuste conforme seu ambiente

# Credenciais de administrador obrigatórias
ADMIN_USER=__SET_ME__
ADMIN_PASS=__SET_ME__

# URL base (opcional — valor padrão apontará para o demo público)
BASE_URL=https://opensource-demo.orangehrmlive.com

# HEADLESS: 'false' para abrir navegador durante desenvolvimento
HEADLESS=true
