{
  "name": "automacao-orange-hrm",
  "version": "1.0.0",
  "description": "Automacao OrangeHRM com Playwright + TypeScript + BDD",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "lint:types": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "playwright test",
    "test:playwright": "playwright test",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:ui": "playwright test --ui",
    "test:cucumber": "cucumber-js --config cucumber.cjs --profile default",
    "test:smoke": "cucumber-js --config cucumber.cjs --profile smoke",
    "test:smoke:retry": "cucumber-js --config cucumber.cjs --profile smoke_retry",
    "test:sanity": "cucumber-js --config cucumber.cjs --profile sanity",
    "test:regression": "cucumber-js --config cucumber.cjs --profile regression",
    "report": "playwright show-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^16.6.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
